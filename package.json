{
  "name": "miras-engagement-api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "build": "node scripts/build-static.mjs",
    "check": "node --check server/*.js && node --check api/*.js && node --check scripts/*.mjs",
    "comments:approve": "node scripts/moderate-comments.mjs approve",
    "comments:list": "node scripts/moderate-comments.mjs list",
    "comments:remove": "node scripts/moderate-comments.mjs remove",
    "migrate": "node scripts/migrate.mjs",
    "test": "node --test",
    "test:watch": "node --test --watch"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "ws": "^8.18.3"
  }
}
